---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { Tooltip } from "@/components/ui/tooltip";
---

<!doctype html>
<html lang="zh-Hans-CN">
  <head>
    <style>
      main {
        margin: 0 auto;
        width: 1024px;
        max-width: calc(100% - 3em);
      }
      .intro {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 80vh;
        user-select: none;
      }
      .info {
        align-self: flex-start;
        display: flex;
        flex-direction: column;
      }
      .title {
        overflow: clip;
        height: fit-content;
      }
      h1 {
        font-size: 120px;
        line-height: 96px;
        transform: translateY(130px);
      }
      h1 span.heu {
        color: #2337ff30;
        font-weight: 600;
        animation: moveup 1s ease forwards;
        display: inline-block;
      }
      h1 span.luck {
        font-weight: 800;
        animation: moveup 1s ease 0.3s forwards;
        display: inline-block;
      }
      .description {
        font-size: 24px;
        color: var(--gray-600);
        display: inline-block;
      }
      @keyframes moveup {
        0% {
          transform: translateY(0);
          opacity: 0;
        }
        100% {
          transform: translateY(-130px);
          opacity: 1;
        }
      }
      @media (max-width: 720px) {
        h1 {
          transform: translateY(0) translateX(-100%);
        }
        h1 span.heu {
          width: 100%;
        }
        h1 span.luck {
          width: 100%;
        }
        @keyframes moveup {
          0% {
            transform: translateY(0);
            opacity: 0;
          }
          100% {
            transform: translateX(100%);
            opacity: 1;
          }
        }
      }
      .links {
        margin-top: 18px;
        align-self: flex-start;
        display: flex;
        gap: 12px;
      }
      .links a {
        color: var(--accent);
        display: inline-block;
      }
    </style>
    <!-- 装饰 -->
    <style>
      .description {
        overflow: clip;
        height: fit-content;
        width: fit-content;
        position: relative;
        margin-bottom: 0.5rem;
      }
      .description::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 5px;
        display: block;
        width: 0px;
        height: 1px;
        background: linear-gradient(
          to right,
          rgba(0, 0, 0, 0.7),
          rgba(0, 0, 0, 0.7) 50%,
          transparent 0,
          transparent
        );
        background-size: 5px 1px;
        animation: 0.5s intro-title-dash 0.7s cubic-bezier(0.6, 0.02, 0.3, 1)
          forwards;
      }
      @keyframes intro-title-dash {
        0% {
          width: 0;
        }

        to {
          width: 100%;
        }
      }
    </style>
    <!-- 临时内容 -->
    <style>
      .under-construction {
        height: 24px;
        overflow: clip;
      }
      .under-construction span {
        height: 24px;
        line-height: 24px;
        display: block;
      }
      .construction-content {
        animation: show-one 10s ease-in-out infinite;
      }
      @keyframes show-one {
        0% {
          transform: translateY(0);
        }
        30% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-24px);
        }
        80% {
          transform: translateY(-24px);
        }
        100% {
          transform: translateY(-48px);
        }
      }
      @media (max-width: 820px) {
        .under-construction {
          height: 72px;
        }
        .under-construction span {
          height: 72px;
        }
        @keyframes show-one {
          0% {
            transform: translateY(0);
          }
          30% {
            transform: translateY(0);
          }
          50% {
            transform: translateY(-72px);
          }
          80% {
            transform: translateY(-72px);
          }
          100% {
            transform: translateY(-144px);
          }
        }
      }
    </style>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="intro">
        <div class="info">
          <div class="title">
            <h1>
              <span class="heu">Heu.</span><span class="luck">Luck</span>
            </h1>
          </div>
          <Tooltip client:load content="前端 | Furry | 昌砖人">
            <span class="description">FE Dev | Furry | NCU</span>
          </Tooltip>
          <div class="under-construction">
            <div class="construction-content">
              <span>🎉 博客完工！喜欢您来 🎉</span>
              <span>🎉 Blog is live! Check it out 🎉</span>
              <span>🎉 博客完工！喜欢您来 🎉</span>
            </div>
          </div>
        </div>
        <div class="links">
          <Tooltip content="GitHub" client:load>
            <a
              href="https://github.com/heuluck"
              target="_blank"
              rel="noopener noreferrer"
              title="GitHub"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                >
                </path><path d="M9 18c-4.51 2-5-2-7-2"></path>
              </svg>
            </a>
          </Tooltip>
          <Tooltip content="Mail" client:load>
            <a
              href="mailto:heuluck@outlook.com"
              target="_blank"
              rel="noopener noreferrer"
              title="Mail"
              data-tooltip-placement="bottom"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <title>e-mail</title>
                <path
                  fill="currentColor"
                  d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2zm-2 0l-8 5l-8-5zm0 12H4V8l8 5l8-5z"
                >
                </path>
              </svg>
            </a>
          </Tooltip>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
