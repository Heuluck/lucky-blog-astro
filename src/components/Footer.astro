---
const today = new Date();
---

<footer>
  <div class="footer-container">
    <div class="footer-content">
      <div class="copyright">
        &copy; 2025-{today.getFullYear()} Heuluck. Powered by Astro.
      </div>
      <div class="social-links">
        <a
          href="https://github.com/heuluck"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            >
            </path><path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
        <a
          href="mailto:heuluck@outlook.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Mail"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
          >
            <title>e-mail</title>
            <path
              fill="currentColor"
              d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2zm-2 0l-8 5l-8-5zm0 12H4V8l8 5l8-5z"
            >
            </path>
          </svg>
        </a>
        <a
          href="/rss.xml"
          aria-label="RSS Feed"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 5rem;
    border-top: 1px solid rgb(var(--gray-light));
    padding: 3rem 0;
  }
  .footer-container {
    width: 1024px;
    max-width: calc(100% - 3em);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .footer-content {
      flex-direction: row;
    }
  }
  .copyright {
    font-size: 0.875rem;
    color: rgb(var(--gray));
  }
  .social-links {
    display: flex;
    gap: 1rem;
  }
  .social-links a {
    color: rgb(var(--gray));
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .social-links a:hover {
    color: rgb(var(--gray-dark));
  }

  /* Dark mode considerations (using your global --gray colors) */
  @media (prefers-color-scheme: dark) {
    footer {
      border-top-color: rgb(var(--gray-dark));
    }
    .social-links a:hover {
      color: #fff;
    }
  }
</style>
