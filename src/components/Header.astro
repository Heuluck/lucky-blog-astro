---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav transition:name="hero">
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/projects">Project</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: center;
    margin: 12px 0;
    position: sticky;
    top: 12px;
    z-index: 1000;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: fit-content;
    background-color: rgba(250, 250, 250, 0.7);
    border-radius: 3em;
    padding: 0.25em 0.25em;
    backdrop-filter: blur(2px);
    box-shadow:
      inset 0 0 2px 1px rgba(255, 255, 255, 1),
      inset 0 -1px 5px rgba(0, 0, 0, 0.1),
      var(--box-shadow);
  }
  nav a {
    padding: 0.125em 1.25em;
    color: var(--black);
    text-decoration: none;
    position: relative;
    font-size: 19px;
  }
  nav a.active {
    color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
