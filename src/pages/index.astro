---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-Hans-CN">
  <head>
    <style>
      main {
        margin: 0 auto;
        width: 1024px;
        max-width: calc(100% - 3em);
      }
      .intro {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 80vh;
        user-select: none;
      }
      .info {
        align-self: flex-start;
        display: flex;
        flex-direction: column;
      }
      .title {
        overflow: clip;
        height: fit-content;
      }
      h1 {
        font-size: 120px;
        line-height: 96px;
        transform: translateY(130px);
      }
      h1 span.heu {
        color: #2337ff30;
        font-weight: 600;
        animation: moveup 1s ease forwards;
        display: inline-block;
      }
      h1 span.luck {
        font-weight: 800;
        animation: moveup 1s ease 0.3s forwards;
        display: inline-block;
      }
      .description {
        font-size: 24px;
        color: var(--gray-600);
        display: inline-block;
      }
      @keyframes moveup {
        0% {
          transform: translateY(0);
          opacity: 0;
        }
        100% {
          transform: translateY(-130px);
          opacity: 1;
        }
      }
      @media (max-width: 720px) {
        h1 {
          transform: translateY(0) translateX(-100%);
        }
        h1 span.heu {
          width: 100%;
        }
        h1 span.luck {
          width: 100%;
        }
        @keyframes moveup {
          0% {
            transform: translateY(0);
            opacity: 0;
          }
          100% {
            transform: translateX(100%);
            opacity: 1;
          }
        }
      }
      .links {
        margin-top: 24px;
        align-self: flex-start;
      }
      .links a {
        color: var(--accent);
      }
    </style>
    <style>
      .under-construction {
        height: 24px;
        overflow: clip;
      }
      .under-construction span {
        height: 24px;
        line-height: 24px;
        display: block;
      }
      .construction-content {
        animation: show-one 5s ease-in-out infinite;
      }
      @keyframes show-one {
        0% {
          transform: translateY(0);
        }
        30% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-24px);
        }
        80% {
          transform: translateY(-24px);
        }
        100% {
          transform: translateY(-48px);
        }
      }
      @media (max-width: 820px) {
        .under-construction {
          height: 72px;
        }
        .under-construction span {
        height: 72px;
      }
        @keyframes show-one {
          0% {
            transform: translateY(0);
          }
          30% {
            transform: translateY(0);
          }
          50% {
            transform: translateY(-72px);
          }
          80% {
            transform: translateY(-72px);
          }
          100% {
            transform: translateY(-144px);
          }
        }
      }
    </style>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="intro">
        <div class="info">
          <div class="title">
            <h1><span class="heu">Heu.</span><span class="luck">Luck</span></h1>
          </div>
          <span class="description">FE Dev | Furry | NCUHOME 2023</span>
          <div class="under-construction">
            <div class="construction-content">
              <span
                >🏗 网站仍在建设中，博客请见 <a
                  href="https://hugo.heuluck.dev"
                  target="_blank"
                  rel="noopener noreferrer">hugo.heuluck.dev</a
                >。</span
              >
              <span
                >🏗 This site is still under construction, visit <a
                  href="https://hugo.heuluck.dev"
                  target="_blank"
                  rel="noopener noreferrer">hugo.heuluck.dev</a
                > to take a look at my blog.</span
              >
              <span
                >🏗 网站仍在建设中，博客请见 <a
                  href="https://hugo.heuluck.dev"
                  target="_blank"
                  rel="noopener noreferrer">hugo.heuluck.dev</a
                >。</span
              >
            </div>
          </div>
        </div>
        <div class="links">
          <a href="https://github.com/heuluck" target="_blank" rel="noopener noreferrer"
            ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
              ><path
                fill="currentColor"
                d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
              ></path></svg
            ></a
          >
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
