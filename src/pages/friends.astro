---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import avatarWrye from "../assets/friends/wrye.webp";
import avatarTitoxd from "../assets/friends/titoxd.webp";
import avatarAsadz from "../assets/friends/Asadz.webp";

interface Friend {
  name: string;
  url: string;
  domain: string;
  avatar: typeof avatarWrye;
}

const friends: Friend[] = [
  {
    name: "Wr's Blog",
    url: "https://wrye.dev/",
    domain: "wrye.dev",
    avatar: avatarWrye,
  },
  {
    name: "头头咖啡屋",
    url: "https://tito.cafe/",
    domain: "tito.cafe",
    avatar: avatarTitoxd,
  },
  {
    name: "雏绒的博客",
    url: "https://asadz.cc/",
    domain: "asadz.cc",
    avatar: avatarAsadz,
  },
];

// 随机排列
for (let i = friends.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [friends[i], friends[j]] = [friends[j], friends[i]];
}
---

<!doctype html>
<html lang="zh-Hans-CN">
  <head>
    <BaseHead title="Luck's Friends" description="我的朋友们" />
    <style>
      main {
        width: 860px;
        max-width: calc(100% - 2em);
        margin: 0 auto;
        padding: 3rem 1rem 5rem;
      }

      /* ── Hero ── */
      .hero {
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 1rem 0 0;
      }
      .hero-title {
        font-size: clamp(2.75rem, 7vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 0.95;
        margin: 0;
        color: rgb(var(--black));
      }
      .hero-sub {
        margin: 1.25rem 0 0;
        max-width: 32em;
        font-size: 1.05rem;
        line-height: 1.7;
        color: rgb(var(--gray));
      }
      .shuffle-note {
        margin: 1rem 0 0;
        font-size: 0.8rem;
        color: rgb(var(--gray));
        opacity: 0.7;
      }

      /* ── 液态玻璃卡片列表 ── */
      .friends-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 0.6dvh;
      }

      /* ── 液态玻璃卡片 — 与导航栏同款 ── */
      .friend-card {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 0.75em 1.5em;
        text-decoration: none;
        color: inherit;
        border-radius: 3em;

        background-color: rgba(250, 250, 250, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow:
          inset 0 0 2px 1px rgba(255, 255, 255, 1),
          inset 0 -1px 5px rgba(0, 0, 0, 0.1),
          var(--box-shadow);

        transition:
          transform 0.3s cubic-bezier(0.25, 0.1, 0, 1),
          box-shadow 0.3s ease,
          background-color 0.3s ease;

        animation: card-rise 0.6s ease both;
        animation-delay: calc(var(--i, 0) * 0.1s);
      }
      @keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .friend-card:hover {
        transform: translateY(-2px);
        box-shadow:
          inset 0 0 2px 1px rgba(255, 255, 255, 1),
          inset 0 -1px 5px rgba(0, 0, 0, 0.15),
          0 16px 32px -12px rgba(0, 0, 0, 0.15),
          0 4px 12px -4px rgba(0, 0, 0, 0.06);
        background-color: rgba(250, 250, 250, 0.85);
      }

      /* ── 头像 ── */
      .friend-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        transition: transform 0.3s ease;
      }
      .friend-card:hover .friend-avatar {
        transform: scale(1.1);
      }

      /* ── 文字区 ── */
      .friend-info {
        flex: 1;
        min-width: 0;
      }
      .friend-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        color: rgb(var(--black));
        line-height: 1.3;
      }
      .friend-domain {
        font-size: 0.78rem;
        color: rgb(var(--gray));
        margin: 2px 0 0;
        font-family: "SF Mono", "Fira Code", "Cascadia Code", monospace;
      }

      /* ── 访问箭头 ── */
      .friend-arrow {
        flex-shrink: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        color: var(--accent);
        transition:
          transform 0.3s cubic-bezier(0.25, 0.1, 0, 1),
          background 0.3s ease;
      }
      .friend-card:hover .friend-arrow {
        transform: translate(2px, -2px);
        background: rgba(var(--gray-light), 0.4);
      }

      /* ── 暗色模式 ── */
      @media (prefers-color-scheme: dark) {
        .hero-title {
          color: #f5f5f7;
        }
        .hero-sub {
          color: #a1a1a6;
        }
        .friend-card {
          background-color: rgba(40, 40, 44, 0.65);
          box-shadow:
            inset 0 0 2px 1px rgba(255, 255, 255, 0.08),
            inset 0 -1px 5px rgba(0, 0, 0, 0.3),
            var(--box-shadow);
        }
        .friend-card:hover {
          background-color: rgba(50, 50, 55, 0.75);
          box-shadow:
            inset 0 0 2px 1px rgba(255, 255, 255, 0.12),
            inset 0 -1px 5px rgba(0, 0, 0, 0.4),
            0 16px 32px -12px rgba(0, 0, 0, 0.5),
            0 4px 12px -4px rgba(0, 0, 0, 0.3);
        }
        .friend-name {
          color: #f5f5f7;
        }
      }

      /* ── 移动端 ── */
      @media (max-width: 720px) {
        .hero {
          min-height: 44vh;
        }
        .hero-title {
          font-size: clamp(2.25rem, 11vw, 3rem);
        }
        .friend-card {
          padding: 0.65em 1.1em;
          gap: 16px;
        }
        .friend-avatar {
          width: 36px;
          height: 36px;
        }
        .friends-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ── 邮箱按钮 ── */
      .email-bar {
        display: flex;
        justify-content: center;
        margin-top: 2.5rem;
      }
      .email-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0.6em 1.5em;
        text-decoration: none;
        color: var(--accent);
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 3em;

        background-color: rgba(250, 250, 250, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow:
          inset 0 0 2px 1px rgba(255, 255, 255, 1),
          inset 0 -1px 5px rgba(0, 0, 0, 0.1),
          var(--box-shadow);

        transition:
          transform 0.3s cubic-bezier(0.25, 0.1, 0, 1),
          box-shadow 0.3s ease,
          background-color 0.3s ease;
      }
      .email-btn:hover {
        transform: translateY(-2px);
        box-shadow:
          inset 0 0 2px 1px rgba(255, 255, 255, 1),
          inset 0 -1px 5px rgba(0, 0, 0, 0.15),
          0 16px 32px -12px rgba(0, 0, 0, 0.15),
          0 4px 12px -4px rgba(0, 0, 0, 0.06);
        background-color: rgba(250, 250, 250, 0.85);
      }
      .email-arrow {
        transition: transform 0.3s ease;
      }
      .email-btn:hover .email-arrow {
        transform: translate(2px, -2px);
      }

      @media (prefers-color-scheme: dark) {
        .email-btn {
          background-color: rgba(40, 40, 44, 0.65);
          box-shadow:
            inset 0 0 2px 1px rgba(255, 255, 255, 0.08),
            inset 0 -1px 5px rgba(0, 0, 0, 0.3),
            var(--box-shadow);
        }
        .email-btn:hover {
          background-color: rgba(50, 50, 55, 0.75);
          box-shadow:
            inset 0 0 2px 1px rgba(255, 255, 255, 0.12),
            inset 0 -1px 5px rgba(0, 0, 0, 0.4),
            0 16px 32px -12px rgba(0, 0, 0, 0.5),
            0 4px 12px -4px rgba(0, 0, 0, 0.3);
        }
      }

      @media (max-width: 720px) {
        .email-btn {
          font-size: 0.85rem;
          padding: 0.55em 1.2em;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="hero">
        <h1 class="hero-title">Luck's Friends</h1>
        <p class="hero-sub">
          一些有趣的灵魂，一些值得停留的地方。如果你也有自己的小站，欢迎来交换友链。
        </p>
      </header>

      <p class="shuffle-note">*随机排列</p>
      <div class="friends-grid">
        {
          friends.map((friend, i) => (
            <a
              class="friend-card"
              href={friend.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--i: ${i}`}
            >
              <Image class="friend-avatar" src={friend.avatar} alt={friend.name} width={80} height={80} />
              <div class="friend-info">
                <h3 class="friend-name">{friend.name}</h3>
                <p class="friend-domain">{friend.domain}</p>
              </div>
              <div class="friend-arrow">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 11L11 3"/>
                  <path d="M5 3h6v6"/>
                </svg>
              </div>
            </a>
          ))
        }
      </div>

      <!-- ═══ 邮箱按钮 ═══ -->
      <div class="email-bar">
        <a class="email-btn" href="mailto:heuluck@outlook.com">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2zm-2 0l-8 5l-8-5zm0 12H4V8l8 5l8-5z"/>
          </svg>
          <span>交换友链？发邮件给我</span>
          <svg class="email-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 11L11 3"/>
            <path d="M5 3h6v6"/>
          </svg>
        </a>
      </div>
    </main>
    <Footer />
  </body>
</html>
